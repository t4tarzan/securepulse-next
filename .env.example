# Neon Postgres (get from https://console.neon.tech)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/securepulse?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/securepulse?sslmode=require

# Stack Auth (get from https://app.stack-auth.com/projects)
NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your-publishable-key
STACK_SECRET_SERVER_KEY=your-secret-server-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub Token (optional — users can connect their own via PAT)
# GITHUB_TOKEN=

# VirusTotal API key (optional — for malware scanning)
# VIRUSTOTAL_API_KEY=
