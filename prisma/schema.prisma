generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String            @id @default(uuid())
  stackAuthId    String?           @unique
  email          String            @unique
  name           String?
  avatarUrl      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userRoles      UserRole[]
  oauthTokens    OAuthToken[]
  githubRepos    GitHubRepository[]
  dockerImages   DockerImage[]
  assignedAlerts AlertAssignment[]
  resolvedAlerts AlertResolution[]
  auditLogs      AuditLog[]

  @@index([email])
  @@index([stackAuthId])
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  userRoles   UserRole[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model GitHubRepository {
  id            String           @id @default(uuid())
  userId        String
  repoName      String
  repoUrl       String
  fullName      String
  visibility    String
  defaultBranch String?
  language      String?
  description   String?
  lastScanned   DateTime?
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans         RepositoryScan[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([userId, fullName])
  @@index([userId])
}

model DockerImage {
  id          String           @id @default(uuid())
  userId      String
  imageName   String
  imageUrl    String
  namespace   String
  repository  String
  lastScanned DateTime?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans       RepositoryScan[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, namespace, repository])
  @@index([userId])
}

model RepositoryScan {
  id            String            @id @default(uuid())
  githubRepoId  String?
  dockerImageId String?
  scanType      String
  status        String            @default("pending")
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  errorMessage  String?
  summary       Json?
  githubRepo    GitHubRepository? @relation(fields: [githubRepoId], references: [id], onDelete: Cascade)
  dockerImage   DockerImage?      @relation(fields: [dockerImageId], references: [id], onDelete: Cascade)
  alerts        Alert[]

  @@index([githubRepoId])
  @@index([dockerImageId])
  @@index([status])
}

model Alert {
  id          String            @id @default(uuid())
  scanId      String
  severity    String
  title       String
  description String
  filePath    String?
  lineNumber  Int?
  commit      String?
  status      String            @default("open")
  scan        RepositoryScan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  assignments AlertAssignment[]
  resolution  AlertResolution?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([scanId])
  @@index([severity])
  @@index([status])
}

model AlertAssignment {
  id         String   @id @default(uuid())
  alertId    String
  assignedTo String
  assignedBy String
  alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [assignedTo], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@index([alertId])
  @@index([assignedTo])
}

model AlertResolution {
  id              String   @id @default(uuid())
  alertId         String   @unique
  resolvedBy      String
  resolutionNotes String
  alert           Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [resolvedBy], references: [id], onDelete: Cascade)
  resolvedAt      DateTime @default(now())

  @@index([resolvedBy])
}

model OAuthToken {
  id           String    @id @default(uuid())
  userId       String
  provider     String
  label        String    @default("default")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider, label])
  @@index([userId])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
}
